# Database
DATABASE_URL=postgresql://user:password@localhost:5432/shop

# Auth
JWT_SECRET=change-me
OTP_EXPIRE=300000
REFRESH_EXPIRE_TIME=604800000

# SMTP (email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASSWORD=password
MAIL_FROM="Shop <no-reply@example.com>"

# Email queue (BullMQ). When false, emails are sent synchronously without Redis.
EMAIL_QUEUE_ENABLED=false
# Supports redis:// and rediss:// (TLS) URLs, including auth credentials.
REDIS_URL=redis://localhost:6379
